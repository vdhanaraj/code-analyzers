{
  "name": "code-analyzers",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "tsc -b",
    "typecheck": "tsc -b",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "biome check .",
    "format": "biome format --write .",
    "ca": "node cli/dist/index.js",
    "prepare": "cd .. && lefthook install"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/node": "^22.10.0",
    "lefthook": "^1.10.0",
    "typescript": "^5.7.0",
    "vitest": "^2.1.0"
  }
}
